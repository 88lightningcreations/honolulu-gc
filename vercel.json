{
  "redirects": [
    {
      "source": "/(.*)",
      "has": [
        {
          "type": "host",
          "value": "www.dumoreconstruction.com"
        }
      ],
      "destination": "https://dumoreconstruction.com/$1",
      "permanent": true
    },
    {
      "source": "/(.*)",
      "has": [
        {
          "type": "host",
          "value": "m.dumoreconstruction.com"
        }
      ],
      "destination": "https://dumoreconstruction.com/$1",
      "permanent": true
    }
  ]
}